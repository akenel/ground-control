# TIG · Tempest — SBX box config.  On the box:  cp deploy/sbx.env.example .env
# Fill EVERY change_me with a strong secret.  Generate one:  openssl rand -base64 36
# (.env is gitignored — never commit it.)

# --- Postgres (tempest's own DB container) ---
POSTGRES_PASSWORD=change_me

# --- MinIO (avatars/banners) ---
MINIO_ROOT_PASSWORD=change_me

# --- tempest-web confidential OIDC client secret ---
#   MUST equal what you pass to ops/provision-realm.py (KC_CLIENT_SECRET).
KC_CLIENT_SECRET=change_me

# --- Session cookie signing key (long + random) ---
SESSION_SECRET=change_me
